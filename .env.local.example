# MongoDB
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/pickups-shopify-app-db?retryWrites=true&w=majority

# Shopify Custom App
SHOPIFY_SHOP=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxxx
# Client Secret from Shopify Admin → Apps → Develop apps → your app → API credentials
# Required scope: read_own_subscription_contracts
SHOPIFY_WEBHOOK_SECRET=your_shopify_client_secret

# Klaviyo
KLAVIYO_API_KEY=pk_xxxxxxxxxxxxx

# App
PICKUP_APP_SECRET=generate_a_random_32_char_string_here
APP_URL=http://localhost:3000
