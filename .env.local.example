# MongoDB — must include a database name before the "?", or Mongoose
# silently writes to the default "test" database.
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/pickups-shopify-app-db?retryWrites=true&w=majority

# Shopify Partners app
SHOPIFY_SHOP=your-store.myshopify.com
# Client Secret from Partners dashboard → your app → API credentials. Server-only.
SHOPIFY_API_SECRET_KEY=your_shopify_client_secret
# API Key (Client ID) from the same page. Public — safe to expose to the client.
NEXT_PUBLIC_SHOPIFY_API_KEY=your_shopify_api_key
# Fallback access token for local dev before the app has been installed once
# via OAuth. Normally the token is read from MongoDB after install.
SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxxx

# Klaviyo
KLAVIYO_API_KEY=pk_xxxxxxxxxxxxx

# App — never expose this one to the client (no NEXT_PUBLIC_ prefix)
PICKUP_APP_SECRET=generate_a_random_32_char_string_here
APP_URL=http://localhost:3000
